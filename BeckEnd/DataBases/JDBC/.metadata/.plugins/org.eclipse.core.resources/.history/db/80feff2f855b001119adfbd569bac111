package com.devanshu.jdbcLearning;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.util.Scanner;

public class LaunchApp10 {

    public static void main(String[] args) {
        Connection connect = null;
        PreparedStatement pstmnt = null;
        ResultSet rs = null;

        try {
            connect = JdbcUtil.getConnection();
            String sql = "select id,sname,sage ,scity form studentinfo where id = ?";
            pstmnt = connect.prepareStatement(sql);

            Scanner scan = new Scanner(System.in);
            System.out.println("Please enter info that needs to be retrive :  ");
            System.out.println("Enter your Id ");
            Integer id = scan.nextInt();
            pstmnt.setInt(1, id);

            rs = pstmnt.executeQuery();

            if (rs.next()) {
                Integer sid = rs.getInt(1);
                String sname = rs.getString(2);
                Integer sage = rs.getInt(3);
                String scity = rs.getString(4);

                System.out.println("Name of the student :" + sname + " IDof student : " + sid + " City of student :"
                        + scity + " Age of student : " + sage);

            } else {
                System.out.println("NOt any record is present on ID " + id);
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}
